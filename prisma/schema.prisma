// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  siteId    String   @unique @default(uuid())
  plan      String   @default("free")
  createdAt DateTime @default(now())
  popups    Popup[]
  contacts  Contact[]
  toasters  Toaster[]
}

model Popup {
  id            String   @id @default(uuid())
  title         String
  message       String
  buttonText    String
  delaySeconds  Int
  views         Int      @default(0)
  conversions   Int      @default(0)
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id])
}

model Contact {
  id        String   @id @default(uuid())
  email     String
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  events    Event[]

  @@unique([userId, email]) // one contact per email, per TrueCatch account
}

model Event {
  id         String   @id @default(uuid())
  type       String   // "popup_submitted", "page_view", "clicked_pricing", etc.
  metadata   Json?    // flexible extra info, e.g. { "popupId": "...", "page": "/pricing" }
  createdAt  DateTime @default(now())

  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id])
}

model Toaster {
  id            String   @id @default(uuid())
  message       String
  ctaText       String?
  ctaUrl        String?
  bgColor       String   @default("#111827")
  triggerType   String   @default("immediate") // "immediate" or "delay"
  delaySeconds  Int      @default(0)
  views         Int      @default(0)
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id])
}