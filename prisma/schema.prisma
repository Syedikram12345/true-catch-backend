// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  siteId    String   @unique @default(uuid())
  plan      String   @default("free")
  createdAt DateTime @default(now())
  popups    Popup[]
  contacts  Contact[]
  toasters  Toaster[]
}

model Popup {
  id            String   @id @default(uuid())
  title         String
  message       String
  buttonText    String
  delaySeconds  Int
  views         Int      @default(0)
  conversions   Int      @default(0)
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id])
}

model PopupView {
  id         String   @id @default(uuid())
  popupId    String
  deviceType String
  browser    String
  os         String
  createdAt  DateTime @default(now())
}

model Contact {
  id         String   @id @default(uuid())
  email      String
  createdAt  DateTime @default(now())

  // Enrichment fields
  firstName  String?
  lastName   String?
  country    String?
  city       String?
  device     String?
  browser    String?
  os         String?
  pageUrl    String?  // first page they visited

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  events     Event[]

  @@unique([userId, email])
}

model Event {
  id          String   @id @default(uuid())
  type        String
  metadata    Json?
  createdAt   DateTime @default(now())

  visitorId   String?  // anonymous visitor ID before email is known
  contactId   String?  // null until visitor is identified
  contact     Contact? @relation(fields: [contactId], references: [id])
}

model Toaster {
  id            String   @id @default(uuid())
  message       String
  ctaText       String?
  ctaUrl        String?
  bgColor       String   @default("#111827")
  triggerType   String   @default("immediate") // "immediate" or "delay"
  delaySeconds  Int      @default(0)
  views         Int      @default(0)
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id])
}